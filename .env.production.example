# ============================================================
# .env.production.example
# Template สำหรับ deploy บน VPS — copy เป็น .env แล้วแก้ค่า
#
# *** ห้าม commit .env ขึ้น git ***
# ============================================================

# Domain ที่ Traefik จะ route มาที่แอป (ตั้ง A record มา VPS IP แล้ว)
DOMAIN=invoice.yourdomain.com

# Password ของ Postgres user (ใช้ openssl rand -base64 24)
DB_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD

# Auth.js secret (ใช้ openssl rand -base64 32)
AUTH_SECRET=CHANGE_ME_TO_RANDOM_32_BYTES
